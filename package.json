{
  "name": "arduino-uno",
  "version": "1.0.0",
  "author": "ArthurZheng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openblock-plugin/arduinoUno.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "npx openblock-registry-cli dev",
    "build": "npx openblock-registry-cli build",
    "build:obfuscate": "npx openblock-registry-cli build --obfuscate",
    "publish": "npx openblock-registry-cli publish",
    "publish:dry": "npx openblock-registry-cli publish --dry-run",
    "validate": "npx openblock-registry-cli validate",
    "i18n:update": "npx openblock-registry-cli i18n update",
    "lint": "eslint . --ext .js --fix"
  },
  "openblock": {
    "name": "Arduino Uno",
    "deviceId": "arduinoUno",
    "manufactor": "arduino.cc",
    "learnMore": "https://docs.arduino.cc/hardware/uno-rev3",
    "type": "arduino",
    "iconURL": "./assets/arduinoUno.png",
    "description": {
      "formatMessage": {
        "id": "arduinoUno.description",
        "default": "A great board to get started with electronics and coding."
      }
    },
    "bluetoothRequired": false,
    "serialportRequired": true,
    "defaultBaudRate": "57600",
    "internetConnectionRequired": false,
    "launchPeripheralConnectionFlow": true,
    "useAutoScan": false,
    "connectionIconURL": "./assets/arduinoUno-illustration.svg",
    "connectionSmallIconURL": "./assets/arduinoUno-small.svg",
    "main": "./src/arduinoUno.js",
    "generator": "./src/generator.js",
    "translations": "./src/translations.js",
    "toolchains": "arduino-arduino-avr",
    "programMode": ["realtime", "upload"],
    "tags": ["arduino"],
    "helpLink": "https://wiki.openblock.cc/general-hardware-guidelines/boards/arduino-uno",
    "libraries": "./libraries",
    "firmwares": [
      { "id": "standard", "name": "Firmata Standard", "file": "./firmwares/arduinoUno.hex" }
    ]
  },
  "devDependencies": {
    "babel-eslint": "^10.0.1",
    "eslint": "^5.3.0",
    "eslint-config-scratch": "^5.0.0",
    "husky": "^9.0.0"
  }
}
